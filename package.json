{
	"name": "uwh-monorepo",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.0.0",
	"workspaces": [
		"frontend",
		"backend"
	],
	"scripts": {
		"dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
		"dev:frontend": "cd frontend && bun run dev",
		"dev:backend": "cd backend && bun run dev",
		"build": "bun run build:frontend && bun run build:backend",
		"build:frontend": "cd frontend && bun run build",
		"build:backend": "cd backend && bun run build",
		"start:backend": "cd backend && bun run start",
		"clean": "rm -rf node_modules frontend/node_modules backend/node_modules frontend/.next"
	},
	"devDependencies": {
		"concurrently": "^8.2.2"
	}
}